# Solana wallet address (used by tracker/meteora modules)
WALLET_ADDRESS=your_solana_wallet_address

# Gmail SMTP — use an App Password, NOT your account password.
# Enable 2-Step Verification, then generate at:
# https://myaccount.google.com/apppasswords
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Recipient for buy-now alerts (defaults to vickomela36@gmail.com)
ALERT_EMAIL=vickomela36@gmail.com

# Notion integration token
# Create an integration at https://www.notion.so/my-integrations
# then share the database with it.
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion database ID — pre-wired to the "Memecoin Buy Now Signals" database.
# Change only if you want to log to a different database.
NOTION_DATABASE_ID=b641d126-bc34-440e-a166-925febc843fc
