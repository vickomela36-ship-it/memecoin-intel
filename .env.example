# ── Gmail (use an App Password, not your main password) ────────────────────────
GMAIL_SENDER=vickomela36@gmail.com
GMAIL_RECIPIENT=vickomela36@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# ── Notion ─────────────────────────────────────────────────────────────────────
# Create an integration at https://www.notion.so/my-integrations and share the
# "Memecoin Buy Now Signals" database with it.
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=685b3530321a4a7ea5af6553774f29b0

# ── Watchlist: comma-separated Solana pair addresses from DexScreener ──────────
# Example: https://dexscreener.com/solana/<pair_address>
WATCHLIST=PairAddress1,PairAddress2,PairAddress3

# ── Signal thresholds (optional — defaults shown) ──────────────────────────────
BUY_MIN_PRICE_CHANGE_24H=10    # minimum 24h price change % to trigger buy
BUY_MIN_VOLUME_24H=10000       # minimum 24h volume in USD
BUY_MIN_LIQUIDITY=5000         # minimum pool liquidity in USD
