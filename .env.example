# Copy to .env and fill in your values

# Gmail SMTP — create an App Password at https://myaccount.google.com/apppasswords
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Alert destination (already set to yours)
ALERT_EMAIL=vickomela36@gmail.com

# Notion integration token — https://www.notion.so/my-integrations
# Share the "Memecoin Buy Signals Log" database with your integration after creating it.
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxx

# Pre-filled — do not change unless you recreate the DB
NOTION_DB_ID=9ef4b2232d1a41649c867a47f8b4350f
NOTION_DATA_SOURCE_ID=73b5d85d-86bf-4b6e-b8d7-c43e92bc0391

# Leave blank to auto-scan trending memecoins, or set comma-separated contract addresses
WATCH_TOKENS=

# Minimum score (0-100) to trigger a 'buy now' signal
BUY_SCORE_THRESHOLD=70
