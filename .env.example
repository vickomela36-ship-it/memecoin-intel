# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# ── Notion ──────────────────────────────────────────────────────────────────
# Create an integration at https://www.notion.so/my-integrations
# and share the "Memecoin Buy Now Signals" database with it.
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Gmail SMTP ───────────────────────────────────────────────────────────────
# Use an App Password (Google Account → Security → App passwords).
# Do NOT use your main account password.
GMAIL_SENDER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Signal settings (optional) ───────────────────────────────────────────────
# Comma-separated token symbols to monitor
TOKENS_TO_MONITOR=PEPE,WIF,BONK,DOGE,SHIB,FLOKI,BRETT,POPCAT,MEW,TURBO

# Score threshold (0–10) above which a signal becomes "buy now"
BUY_SIGNAL_THRESHOLD=6.0
