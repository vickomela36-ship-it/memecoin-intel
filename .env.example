# ─── Gmail ────────────────────────────────────────────────────────────────────
# Use a Gmail App Password (NOT your account password).
# Enable: https://support.google.com/accounts/answer/185833
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Alert destination
ALERT_EMAIL=vickomela36@gmail.com

# ─── Notion ───────────────────────────────────────────────────────────────────
# Create an integration at https://www.notion.so/my-integrations
# then share the "Memecoin Buy Signals Log" database with it.
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Pre-filled — the existing "Memecoin Buy Signals Log" database
NOTION_DATABASE_ID=8ee78806328945b987038fd78cf405b6

# ─── DexScreener ──────────────────────────────────────────────────────────────
# Chain to monitor: solana | ethereum | bsc | base | arbitrum …
DEXSCREENER_CHAIN=solana

# ─── Signal thresholds (optional) ─────────────────────────────────────────────
BUY_SIGNAL_MIN_PRICE_CHANGE_5M=3.0   # % gain in 5 min
BUY_SIGNAL_MIN_PRICE_CHANGE_1H=8.0   # % gain in 1 hour
BUY_SIGNAL_MIN_VOLUME_5M=5000        # USD volume in last 5 min
BUY_SIGNAL_MIN_LIQUIDITY=30000       # USD liquidity on the pair
