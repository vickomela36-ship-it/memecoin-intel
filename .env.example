# ── Gmail (SMTP) ─────────────────────────────────────────────────────────────
# Your Gmail address (the sender)
GMAIL_USER=your_address@gmail.com

# 16-character App Password from https://myaccount.google.com/apppasswords
# (requires 2FA enabled on your Google account)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Notion ────────────────────────────────────────────────────────────────────
# Internal integration token from https://www.notion.so/my-integrations
# Must have access to the "Memecoin Buy Now Signals" database
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Signal tuning (optional) ──────────────────────────────────────────────────
# Minimum 1h price change % to trigger a buy signal (default: 20)
# BUY_MIN_CHANGE_1H=20

# Minimum liquidity in USD (default: 10000)
# BUY_MIN_LIQUIDITY=10000

# Minimum volume/liquidity ratio (default: 0.5)
# BUY_MIN_VOL_LIQ_RATIO=0.5

# Chain to monitor — "solana", "ethereum", "bsc", or "" for all (default: solana)
# TARGET_CHAIN=solana
