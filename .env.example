# Copy this to .env (never commit .env)

# Notion integration token (Settings → Integrations → New integration)
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Gmail sender address
GMAIL_USER=you@gmail.com

# Gmail App Password (Google Account → Security → App passwords)
# Must have 2-Step Verification enabled
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Optional: your Solana wallet for Meteora LP monitor
WALLET_ADDRESS=

# Optional: override signal thresholds
BUY_MIN_PRICE_CHANGE_24H=15
BUY_MIN_VOLUME_TO_MCAP=0.10
BUY_MIN_MARKET_CAP=1000000
