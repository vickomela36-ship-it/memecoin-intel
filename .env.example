# ── Gmail SMTP ────────────────────────────────────────────────────────────────
# Use an App Password: https://myaccount.google.com/apppasswords
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Alert recipient (buy-now emails go here)
ALERT_EMAIL=vickomela36@gmail.com

# ── Notion ────────────────────────────────────────────────────────────────────
# Create an integration at https://www.notion.so/my-integrations
# and share the "Memecoin Buy Now Signals" database with it.
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion database ID — defaults to the pre-created "Memecoin Buy Now Signals" DB
# NOTION_DATABASE_ID=b641d126-bc34-440e-a166-925febc843fc

# ── Solana wallet (optional, for future PnL tracking) ─────────────────────────
# WALLET_ADDRESS=

# ── Signal thresholds ─────────────────────────────────────────────────────────
# Minimum 1h price change % to qualify as a buy signal (default: 10)
# BUY_SIGNAL_PRICE_CHANGE_1H=10.0

# Minimum 24h volume in USD (default: 50000)
# BUY_SIGNAL_VOLUME_MIN=50000

# How often to check for signals in hours (default: 1)
# CHECK_INTERVAL_HOURS=1
