# Copy this to .env and fill in your values.
# Never commit .env to git.

# Gmail SMTP — use a Google App Password (not your account password).
# Enable 2FA first, then create an App Password at:
# https://myaccount.google.com/apppasswords
GMAIL_SENDER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# Notion Integration Token — create at https://www.notion.so/my-integrations
# Share the "Memecoin Buy Signals Log" database with the integration.
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: comma-separated Solana token addresses to monitor.
# Leave blank to auto-fetch trending tokens from DexScreener.
WATCH_TOKENS=
