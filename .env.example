# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Gmail SMTP sender credentials
GMAIL_USER=your-sender@gmail.com
GMAIL_APP_PASS=xxxx-xxxx-xxxx-xxxx   # Gmail App Password (not your login password)

# Notion internal integration token
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Comma-separated DexScreener Solana pair addresses to monitor
TRACKED_PAIRS=So11111111111111111111111111111111111111112,<another_pair>

# Notion DB ID (auto-set by Claude setup — change only if you recreate the DB)
NOTION_DB_ID=44763c62-4d07-4fde-bb1c-503846807aeb

# Check interval in seconds (default 3600 = 1 hour)
CHECK_INTERVAL_SECONDS=3600
