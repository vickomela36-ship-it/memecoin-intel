# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Gmail – sender account + App Password
# Get an App Password at: https://myaccount.google.com/apppasswords
GMAIL_SENDER_EMAIL=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Alert destination (default already set to vickomela36@gmail.com in config.py)
# ALERT_RECIPIENT=vickomela36@gmail.com

# Notion Internal Integration token
# Create one at: https://www.notion.so/my-integrations
# Then share the "Memecoin Buy Now Signals" database with the integration.
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion database ID (pre-filled with the created database)
NOTION_DATABASE_ID=685b3530-321a-4a7e-a5af-6553774f29b0
