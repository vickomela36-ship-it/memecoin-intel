# Copy this file to .env and fill in your credentials.
# Never commit .env to version control.

# Notion integration token (from https://www.notion.so/my-integrations)
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion database ID for signal logging (pre-created sheet)
NOTION_DATABASE_ID=347d4906-1af0-4a12-b116-e0601217bcaf

# Gmail address that sends alerts
GMAIL_SENDER=you@gmail.com

# Gmail App Password (https://myaccount.google.com/apppasswords)
# Use an App Password, NOT your account password.
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Recipient email for buy now alerts
ALERT_EMAIL=vickomela36@gmail.com
