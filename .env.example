# Copy this file to .env and fill in your credentials
# Never commit .env to version control

# Notion integration token — create one at https://www.notion.so/my-integrations
# Share the 'Memecoin Buy Signals' database with the integration
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Gmail address and app password — generate at https://myaccount.google.com/apppasswords
# (Enable 2FA first, then create an app password for 'Mail')
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
