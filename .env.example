# Notion integration token (from https://www.notion.so/my-integrations)
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxx

# Gmail sender address and App Password
# Generate App Password at: https://myaccount.google.com/apppasswords
GMAIL_SENDER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Buy signal thresholds (optional - defaults shown)
BUY_SIGNAL_MIN_VOLUME_USD=100000
BUY_SIGNAL_MIN_PRICE_CHANGE_PCT=5.0
BUY_SIGNAL_MIN_LIQUIDITY_USD=50000
