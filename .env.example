# Copy this to .env and fill in your credentials
# Then: source .env before running, OR add these to /etc/environment

# Your Gmail address (the one sending the alert)
GMAIL_SENDER=you@gmail.com

# Gmail App Password — generate at: myaccount.google.com/apppasswords
# (requires 2FA to be enabled on your Google account)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Recipient for BUY NOW alerts (already set in config.py, override here if needed)
ALERT_EMAIL=vickomela36@gmail.com

# Notion Internal Integration Token
# Create one at: notion.so/my-integrations → New integration → copy "Internal Integration Secret"
# Then share the "Memecoin Buy Now Signals" database with that integration
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
