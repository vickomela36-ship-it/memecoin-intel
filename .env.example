# Copy this to .env and fill in your values, then:
#   export $(grep -v '^#' .env | xargs)
# Or add them directly to your crontab environment block.

# Gmail — use a Google App Password (NOT your login password)
# Generate at: https://myaccount.google.com/apppasswords
GMAIL_SENDER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Notion integration token
# Create at: https://www.notion.so/my-integrations
# Then share the "Memecoin Buy Signals Log" database with your integration.
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: your Solana wallet for PnL tracking
WALLET_ADDRESS=
