# ── Gmail SMTP ────────────────────────────────────────────────────────────────
# Your Gmail address (the sender)
GMAIL_USER=your_gmail@gmail.com

# Generate at https://myaccount.google.com/apppasswords  (16-char app password)
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Alert recipient — buy-now emails are sent here
ALERT_EMAIL=vickomela36@gmail.com

# ── Notion ────────────────────────────────────────────────────────────────────
# Create an integration at https://www.notion.so/my-integrations
# then share the "Memecoin Buy Now Signals" database with it
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The Notion database ID (pre-configured; change only if you created a new DB)
NOTION_DB_ID=4c5532436f5046579b4b0da6cd5fd89a

# ── Signal tuning ─────────────────────────────────────────────────────────────
# Score threshold (0-100) above which a token triggers a "buy now" signal
BUY_SCORE_THRESHOLD=70

# Comma-separated contract addresses to watch; leave empty to scan trending pairs
WATCH_TOKENS=
