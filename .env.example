# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Notion integration token (from https://www.notion.so/my-integrations)
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Gmail sender address and App Password
# Generate an App Password at: https://myaccount.google.com/apppasswords
# (Requires 2-Step Verification to be enabled on your Google account)
GMAIL_SENDER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Optional: comma-separated Solana/EVM token addresses to watch.
# Leave blank to auto-watch DexScreener trending/boosted tokens.
WATCH_LIST=
