# Copy this file to .env and fill in your credentials.
# The scheduler and check_signals.py read these at startup.

# Gmail App Password (myaccount.google.com/apppasswords)
GMAIL_SENDER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Notion integration token (notion.so/my-integrations)
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
