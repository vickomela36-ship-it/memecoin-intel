# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real credentials.

# ── Gmail ────────────────────────────────────────────────────────────────────
# Your Gmail address (the sender)
GMAIL_SENDER=you@gmail.com

# Gmail App Password (NOT your normal Gmail password).
# Generate at: https://myaccount.google.com/apppasswords
# Requires 2-Step Verification to be enabled on the account.
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Notion ───────────────────────────────────────────────────────────────────
# Internal Integration Token from https://www.notion.so/profile/integrations
# Share the "Memecoin Buy Signals" database with the integration before use.
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
