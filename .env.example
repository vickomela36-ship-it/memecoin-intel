# Gmail sender account (must have 2FA enabled)
GMAIL_FROM_ADDRESS=your_gmail@gmail.com

# Gmail App Password — generate at https://myaccount.google.com/apppasswords
# Format: four 4-letter groups separated by spaces, e.g. "abcd efgh ijkl mnop"
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Notion Integration Token — create at https://www.notion.so/my-integrations
# Then share the "Memecoin Buy Now Signals" database with the integration
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion database ID (pre-filled with existing DB — change only if needed)
NOTION_DATABASE_ID=958c4eaa-7978-470a-87a4-8b2bcf1e3cf3
