# Copy this file to .env and fill in your values

# Gmail SMTP (create an App Password at https://myaccount.google.com/apppasswords)
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Alert destination (already set to yours, change if needed)
ALERT_EMAIL=vickomela36@gmail.com

# Notion integration token (get at https://www.notion.so/my-integrations)
# Then share the "Memecoin Buy Signals Log" database with your integration
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxx

# Notion database ID (pre-filled — do not change unless you recreate the DB)
NOTION_DB_ID=5ee05dcac8a4463fbf5639a2eb08f364

# Optional: comma-separated Solana/ETH token contract addresses to watch
# Leave blank to scan trending memecoins automatically
WATCH_TOKENS=

# Minimum score (0-100) for a 'buy now' signal (default 70)
BUY_SCORE_THRESHOLD=70
