# Copy this file to .env and fill in your credentials.
# Source it before running: source .env
# Or let the cron entry handle it (see README / crontab setup).

# Gmail: use an App Password (not your main password).
# Create one at https://myaccount.google.com/apppasswords
GMAIL_SENDER=your-gmail@gmail.com
GMAIL_APP_PASS=xxxx-xxxx-xxxx-xxxx

# Notion integration token (secret_xxx...)
# Create one at https://www.notion.so/my-integrations
# and share the "Memecoin Buy Signals" database with it.
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
