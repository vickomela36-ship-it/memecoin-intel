# Gmail SMTP — use an App Password (NOT your main account password)
# Generate one at: https://myaccount.google.com/apppasswords
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Who receives the alert emails
ALERT_EMAIL=vickomela36@gmail.com

# Notion integration token
# Create an integration at: https://www.notion.so/my-integrations
# Then share the "Memecoin Buy Now Signals" database with it
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxx

# Pre-created Notion database ID ("Memecoin Buy Now Signals")
NOTION_DB_ID=b641d126bc34440ea166925febc843fc

# Optional: comma-separated token symbols or contract addresses to watch
# Leave empty to auto-scan trending memecoins on Solana/Ethereum/Base
WATCH_TOKENS=

# Minimum score (0-100) to trigger a "buy now" signal (default: 70)
BUY_SCORE_THRESHOLD=70
