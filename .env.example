# ── Gmail SMTP ────────────────────────────────────────────────────────────────
# Your Gmail address (the sender)
EMAIL_SENDER=you@gmail.com

# Gmail App Password (not your account password).
# Generate one at: https://myaccount.google.com/apppasswords
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Notion ────────────────────────────────────────────────────────────────────
# Create an internal integration at https://www.notion.so/my-integrations
# then share the "Memecoin Buy Signals Log" database with it.
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── CoinGecko (optional) ──────────────────────────────────────────────────────
# Free Demo API key from https://www.coingecko.com/en/api → raises rate limits
COINGECKO_API_KEY=

# ── Wallet (optional, for future on-chain features) ───────────────────────────
WALLET_ADDRESS=
