# ── Gmail (SMTP) ─────────────────────────────────────────────────────────────
# The Gmail account that sends alerts.
GMAIL_ADDRESS=your_gmail@gmail.com

# Generate an App Password (NOT your regular password) at:
# https://myaccount.google.com/apppasswords
# Requires 2-Step Verification to be enabled on your Google account.
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# ── Notion ────────────────────────────────────────────────────────────────────
# Integration token from https://www.notion.so/my-integrations
# Make sure the integration has access to the "Memecoin Buy Signals Log" database.
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Override only if you use a different database (default is the pre-created one)
# NOTION_DATABASE_ID=9ef4b2232d1a41649c867a47f8b4350f

# ── Signal settings (optional overrides) ─────────────────────────────────────
CHAIN=solana
MIN_PRICE_CHANGE_5M=3.0
MIN_PRICE_CHANGE_1H=8.0
MIN_VOLUME_1H_USD=30000
MIN_LIQUIDITY_USD=5000
BUY_CONFIDENCE_THRESHOLD=0.65
