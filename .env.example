# Your Solana wallet address
WALLET_ADDRESS=your_solana_wallet_address_here

# Comma-separated Solana token contract addresses to monitor
# Example uses Wrapped SOL and USDC — replace with actual memecoins
WATCHED_TOKENS=So11111111111111111111111111111111111111112,EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# Gmail — create an App Password at https://myaccount.google.com/apppasswords
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Notion integration token — create one at https://www.notion.so/my-integrations
# Make sure the integration has access to the "Memecoin Buy Signals" database
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Optional signal thresholds (defaults shown) ---
# BUY_MIN_1H_CHANGE=3.0      # minimum 1h price change % to trigger buy
# BUY_MIN_VOLUME_24H=50000   # minimum 24h volume (USD)
# BUY_MIN_LIQUIDITY=10000    # minimum liquidity (USD)
# BUY_MIN_BUY_PRESSURE=0.55  # minimum buy/(buy+sell) ratio
# SELL_MAX_1H_CHANGE=-8.0    # 1h drop below this triggers sell
# SELL_MAX_BUY_PRESSURE=0.30 # buy pressure below this triggers sell
