# Notion integration token (Settings → Integrations → New integration)
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Gmail credentials for outbound alerts
GMAIL_USER=your-gmail@gmail.com
# Generate at: myaccount.google.com/apppasswords (requires 2FA)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Override recipient (defaults to vickomela36@gmail.com)
# ALERT_EMAIL=vickomela36@gmail.com
