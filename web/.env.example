# Copy to .env.local and fill in. NEVER commit .env.local.
#
# These are SERVER-SIDE keys (no NEXT_PUBLIC_ prefix) — they are used only
# inside Next.js API routes, so they never reach the browser bundle.
# football-data.org also blocks browser CORS, so proxying is required anyway.

# https://www.football-data.org/client/register  (free: 10 req/min)
FOOTBALL_DATA_API_KEY=

# https://the-odds-api.com/#get-access  (free: 500 req/month)
ODDS_API_KEY=
