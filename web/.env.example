# Copy to .env.local and fill in. NEVER commit .env.local.
#
# These are SERVER-SIDE keys (no NEXT_PUBLIC_ prefix) — they are used only
# inside Next.js API routes, so they never reach the browser bundle.
# football-data.org also blocks browser CORS, so proxying is required anyway.

# https://www.football-data.org/client/register  (free: 10 req/min)
FOOTBALL_DATA_API_KEY=

# https://the-odds-api.com/#get-access  (free: 500 req/month)
ODDS_API_KEY=

# Whale/insider intel (optional — defaults exist for this project)
# https://helius.dev (free tier)  https://birdeye.so (free tier)
HELIUS_API_KEY=
BIRDEYE_API_KEY=

# Telegram alerts — create a bot via @BotFather, paste its token here.
# TELEGRAM_CHAT_ID is optional (auto-detected after you message the bot).
# ALERTS_SECRET protects /api/alerts from strangers triggering it.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALERTS_SECRET=
